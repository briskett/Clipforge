{"segments": [{"start": 0.031, "end": 2.276, "text": " Don't you dare bot me, I am risking this.", "words": [{"word": "Don't", "start": 0.031, "end": 0.272, "score": 0.607}, {"word": "you", "start": 0.332, "end": 0.432, "score": 0.995}, {"word": "dare", "start": 0.572, "end": 0.833, "score": 0.968}, {"word": "bot", "start": 0.933, "end": 1.154, "score": 0.854}, {"word": "me,", "start": 1.174, "end": 1.294, "score": 0.884}, {"word": "I", "start": 1.454, "end": 1.494, "score": 0.991}, {"word": "am", "start": 1.574, "end": 1.635, "score": 0.806}, {"word": "risking", "start": 1.715, "end": 2.036, "score": 0.854}, {"word": "this.", "start": 2.076, "end": 2.276, "score": 0.974}]}, {"start": 6.265, "end": 9.653, "text": "Oh my, the ancient godsword here coming in clutch there.", "words": [{"word": "Oh", "start": 6.265, "end": 6.385, "score": 0.72}, {"word": "my,", "start": 6.646, "end": 7.067, "score": 0.93}, {"word": "the", "start": 7.107, "end": 7.247, "score": 0.591}, {"word": "ancient", "start": 7.327, "end": 7.608, "score": 0.921}, {"word": "godsword", "start": 7.728, "end": 8.169, "score": 0.846}, {"word": "here", "start": 8.209, "end": 8.43, "score": 0.72}, {"word": "coming", "start": 8.47, "end": 8.711, "score": 0.687}, {"word": "in", "start": 8.751, "end": 8.831, "score": 0.799}, {"word": "clutch", "start": 8.931, "end": 9.352, "score": 0.671}, {"word": "there.", "start": 9.392, "end": 9.653, "score": 0.676}]}, {"start": 9.913, "end": 10.475, "text": "Wait, what?", "words": [{"word": "Wait,", "start": 9.913, "end": 10.134, "score": 0.919}, {"word": "what?", "start": 10.194, "end": 10.475, "score": 0.949}]}, {"start": 11.076, "end": 12.98, "text": "Level 52 infernal cave.", "words": [{"word": "Level", "start": 11.076, "end": 11.417, "score": 0.852}, {"word": "52", "start": 11.437, "end": 11.898, "score": 0.881}, {"word": "infernal", "start": 12.178, "end": 12.619, "score": 0.928}, {"word": "cave.", "start": 12.68, "end": 12.98, "score": 0.93}]}, {"start": 13.261, "